@using Alife.Framework.UI
@using Alife.Plugin.ImageGen
@inject ImageGenModule Module

<div class="card mb-3">
    <div class="card-header">
        <h5>AI 图片生成配置</h5>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label">API 接口地址</label>
            <input type="url" class="form-control" @bind="Module.Configuration!.ApiEndpoint"
                   placeholder="https://api.openai.com/v1/images/generations" />
            <small class="text-muted">支持 OpenAI 格式接口及 Stable Diffusion API</small>
        </div>

        <div class="mb-3">
            <label class="form-label">API Key</label>
            <input type="password" class="form-control" @bind="Module.Configuration!.ApiKey"
                   placeholder="sk-..." />
            <small class="text-muted">你的 API 密钥</small>
        </div>

        <div class="mb-3">
            <label class="form-label">模型名称</label>
            <input type="text" class="form-control" @bind="Module.Configuration!.Model"
                   placeholder="dall-e-3 / stable-diffusion-xl-1024-v1-0" />
        </div>

        <div class="row g-3 mb-3">
            <div class="col">
                <label class="form-label">默认宽度</label>
                <input type="number" class="form-control" @bind="Module.Configuration!.DefaultWidth" min="256" step="64" />
            </div>
            <div class="col">
                <label class="form-label">默认高度</label>
                <input type="number" class="form-control" @bind="Module.Configuration!.DefaultHeight" min="256" step="64" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">可用尺寸列表（每行一个，格式：宽x高）</label>
            <textarea class="form-control" rows="4"
                      @bind="SupportedSizesText"></textarea>
        </div>

        <button class="btn btn-primary" @onclick="SaveConfig">保存配置</button>
    </div>
</div>

@code {
    private string SupportedSizesText
    {
        get => string.Join("\n", Module.Configuration?.SupportedSizes ?? new());
        set => Module.Configuration!.SupportedSizes = value
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
    }

    private async Task SaveConfig()
    {
        if (Module.Configuration != null)
        {
            await Module.SaveConfigAsync();
        }
    }
}